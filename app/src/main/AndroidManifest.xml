<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 用于查询已安装应用 (Root 管理器、Xposed 模块包名检测) -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission"
        xmlns:tools="http://schemas.android.com/tools" />

    <!-- SSL Pinning self-test (sp.pin_selftest): tries to make an HTTPS handshake
         with a reject-all TrustManager and expects an SSLHandshakeException.
         Without INTERNET the call short-circuits with SecurityException. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Catched">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Catched">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>